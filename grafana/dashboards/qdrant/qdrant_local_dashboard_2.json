    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_running_optimizations",
          "instant": false,
          "legendFormat": "{{id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Running Optimizations Per Collection",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "drawStyle": "line",
            "fillOpacity": 15, "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "transparent", "value": 0 },
            { "color": "semi-dark-orange", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_update_queue_deferred_points",
          "instant": false,
          "legendFormat": "deferred points {{id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Deferred Points (pending optimization) Per Collection",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_indexed_only_excluded_points",
          "instant": false,
          "legendFormat": "excluded {{id}} / {{vector}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "indexed_only Excluded Points (not yet indexed)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": 0 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "running_optimizations" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "deferred_points" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 },
                { "color": "orange", "value": 1 }
              ]}}
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "id": 23,
      "options": { "cellHeight": "sm", "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_running_optimizations",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_update_queue_deferred_points",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_update_queue_length",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_shard_transfer_incoming",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_collection_shard_transfer_outgoing",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "E"
        }
      ],
      "title": "Collection Optimization Status (current snapshot)",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "id", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true,
              "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true
            },
            "renameByName": {
              "id": "collection_id",
              "Value #A": "running_optimizations",
              "Value #B": "deferred_points",
              "Value #C": "update_queue_length",
              "Value #D": "shard_transfer_incoming",
              "Value #E": "shard_transfer_outgoing"
            }
          }
        }
      ],
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 300,
      "title": "REST API Deep-Dive (Per Endpoint)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": 0 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg_duration_s" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 4 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.1 },
                { "color": "red", "value": 0.5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "max_duration_s" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "red", "value": 2 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "min_duration_s" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] } },
              { "id": "mappings", "value": [
                { "options": {
                  "pattern": "2..",
                  "result": { "color": "green", "index": 0 }
                }, "type": "regex" },
                { "options": {
                  "pattern": "4..",
                  "result": { "color": "orange", "index": 1 }
                }, "type": "regex" },
                { "options": {
                  "pattern": "5..",
                  "result": { "color": "red", "index": 2 }
                }, "type": "regex" }
              ]}
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "avg_duration_s" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_rest_responses_total",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_rest_responses_avg_duration_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_rest_responses_min_duration_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "qdrant_rest_responses_max_duration_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "D"
        }
      ],
      "title": "Per-Endpoint Summary (latency + request count)",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "endpoint", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
              "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true,
              "method 2": true, "method 3": true, "method 4": true,
              "status 2": true, "status 3": true, "status 4": true
            },
            "renameByName": {
              "endpoint": "endpoint",
              "method 1": "method",
              "status 1": "status",
              "Value #A": "total_requests",
              "Value #B": "avg_duration_s",
              "Value #C": "min_duration_s",
              "Value #D": "max_duration_s"
            }
          }
        }
      ],
      "type": "table"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
